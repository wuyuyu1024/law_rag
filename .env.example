# Demo runtime settings
TAX_RAG_ENV=dev
TAX_RAG_LOG_LEVEL=INFO

# Data locations
TAX_RAG_RAW_DATA_DIR=data/raw
TAX_RAG_PARSED_DATA_DIR=data/parsed
TAX_RAG_CHUNKS_DIR=data/chunks
TAX_RAG_EVAL_DIR=data/eval

# Retrieval and security defaults
TAX_RAG_DEFAULT_ROLE=helpdesk
TAX_RAG_DEFAULT_TOP_K=10
TAX_RAG_SECURITY_MODE=demo

# Optional infrastructure-backed cache
REDIS_URL=redis://localhost:6379/0
